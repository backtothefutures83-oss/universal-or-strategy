{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.SignalR": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{BuildTag}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/morpheus-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{BuildTag}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "127.0.0.1",
  "Morpheus": {
    "StateStorePath": "morpheus.db",
    "Rithmic": {
      "Endpoint": "stub://localhost",
      "GatewayHost": "localhost",
      "GatewayPort": 0,
      "SystemName": "stub",
      "UserId": "stub-user",
      "Password": "stub-password"
    },
    "MarketData": {
      "BarBufferCapacity": 512
    },
    "Accounts": [
      { "Id": "default" }
    ]
  }
}
