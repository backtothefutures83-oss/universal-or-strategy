ull,"original_start_line":null,"start_side":null,"line":66,"original_line":66,"side":"RIGHT","author_association":"NONE","original_position":66,"position":66,"subject_type":"line"},{"url":"https://api.github.com/repos/mdasdispatch-hash/universal-or-strategy/pulls/comments/3293359013","pull_request_review_id":4351322334,"id":3293359013,"node_id":"PRRC_kwDOSjZ7L87ETKul","diff_hunk":"@@ -251,6 +251,10 @@ private struct QueuedAccountOrderUpdate\n         // [EPIC-5-PERF T04] Order array pool for zero-allocation SIMA propagation\n         private OrderArrayPool _orderArrayPool;\n \n+        // [EPIC-5-PERF T06] Proximity tag cache for RMA sentinel draw object management\n+        private readonly HashSet<string> _proxTagCache = new HashSet<string>();\n+        private const int PROX_TAG_CACHE_LIMIT = 1000;","path":"src/V12_002.cs","commit_id":"df67ac32970213dd75790a099f41c1505160512f","original_commit_id":"df67ac32970213dd75790a099f41c1505160512f","user":{"login":"codacy-production[bot]","id":61871480,"node_id":"MDM6Qm90NjE4NzE0ODA=","avatar_url":"https://avatars.githubusercontent.com/in/56611?v=4","gravatar_id":"","url":"https://api.github.com/users/codacy-production%5Bbot%5D","html_url":"https://github.com/apps/codacy-production","followers_url":"https://api.github.com/users/codacy-production%5Bbot%5D/followers","following_url":"https://api.github.com/users/codacy-production%5Bbot%5D/following{/other_user}","gists_url":"https://api.github.com/users/codacy-production%5Bbot%5D/gists{/gist_id}","starred_url":"https://api.github.com/users/codacy-production%5Bbot%5D/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/codacy-production%5Bbot%5D/subscriptions","organizations_url":"https://api.github.com/users/codacy-production%5Bbot%5D/orgs","repos_url":"https://api.github.com/users/codacy-production%5Bbot%5D/repos","events_url":"https://api.github.com/users/codacy-production%5Bbot%5D/events{/privacy}","received_events_url":"https://api.github.com/users/codacy-production%5Bbot%5D/received_events","type":"Bot","user_view_type":"public","site_admin":false},"body":"<sub>:red_circle: HIGH RISK</sub>\n\nThis addition contradicts the 'Documentation-only' requirement stated in the PR description. Furthermore, the `HashSet<string>` is not thread-safe. In the NinjaTrader environment (Strategy vs. UI threads) and under the 'No internal locks' DNA mandate, this collection is prone to race conditions and corruption. Consider using a `ConcurrentDictionary<string, byte>` or an Actor-based encapsulation to manage this set safely. Additionally, ensure pruning logic is implemented to enforce the cache limit.\n<!-- e34d5167-b092-49eb-b8c8-33859ab00079 -->","created_at":"2026-05-23T19:11:38Z","updated_at":"2026-05-23T19:11:38Z","html_url":"https://github.com/mdasdispatch-hash/universal-or-strategy/pull/8#discussion_r3293359013","pull_request_url":"https://api.github.com/repos/mdasdispatch-hash/universal-or-strategy/pulls/8","_links":{"self":{"href":"https://api.github.com/repos/mdasdispatch-hash/universal-or-strategy/pulls/comments/3293359013"},"html":{"href":"https://github.com/mdasdispatch-hash/universal-or-strategy/pull/8#discussion_r3293359013"},"pull_request":{"href":"https://api.github.com/repos/mdasdispatch-hash/universal-or-strategy/pulls/8"}},"reactions":{"url":"https://api.github.com/repos/mdasdispatch-hash/universal-or-strategy/pulls/comments/3293359013/reactions","total_count":0,"+1":0,"-1":0,"laugh":0,"hooray":0,"confused":0,"heart":0,"rocket":0,"eyes":0},"start_line":null,"original_start_line":255,"start_side":"RIGHT","line":null,"original_line":256,"side":"RIGHT","author_association":"NONE","original_position":15,"position":1,"subject_type":"line"},{"url":"https://api.github.com/repos/mdasdispatch-hash/universal-or-strategy/pulls/comments/3293359016","pull_request_review_id":4351322334,"id":3293359016,"node_id":"PRRC_kwDOSjZ7L87ETKuo","diff_hunk":"@@ -44,7 +44,7 @@ namespace NinjaTrader.NinjaScript.Strategies\n {\n     public partial class V12_002 : Strategy\n     {\n-        public const string BUILD_TAG = \"1111.010-epic5-perf\"; // EPIC-5 Ticket 04: Order Array Pooling\n+        public const string BUILD_TAG = \"1111.011-epic6-testing\"; // EPIC-6 Phase 1: Performance Lock-In (Automated Testing)","path":"src/V12_002.cs","commit_id":"9c67e2323c1f151f4988b14e9424b3e185d69d18","original_commit_id":"df67ac32970213dd75790a099f41c1505160512f","user":{"login":"codacy-production[bot]","id":61871480,"node_id":"MDM6Qm90NjE4NzE0ODA=","avatar_url":"https://avatars.githubusercontent.com/in/56611?v=4","gravatar_id":"","url":"https://api.github.com/users/codacy-production%5Bbot%5D","html_url":"https://github.com/apps/codacy-production","followers_url":"https://api.github.com/users/codacy-production%5Bbot%5D/followers","following_url":"https://api.github.com/users/codacy-production%5Bbot%5D/following{/other_user}","gists_url":"https://api.github.com/users/codacy-production%5Bbot%5D/gists{/gist_id}","starred_url":"https://api.github.com/users/codacy-production%5Bbot%5D/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/codacy-production%5Bbot%5D/subscriptions","organizations_url":"https://api.github.com/users/codacy-production%5Bbot%5D/orgs","repos_url":"https://api.github.com/users/codacy-production%5Bbot%5D/repos","events_url":"https://api.github.com/users/codacy-production%5Bbot%5D/events{/privacy}","received_events_url":"https://api.github.com/users/codacy-production%5Bbot%5D/received_events","type":"Bot","user_view_type":"public","site_admin":false},"body":"<sub>:yellow_circle: MEDIUM RISK</sub>\n\nChange this constant to a 'static readonly' field. This prevents compile-time inlining into external assemblies and ensures the version tag is fetched at runtime.\n\n```suggestion\n        public static readonly string BUILD_TAG = \"1111.011-epic6-testing\"; // EPIC-6 Phase 1: Performance Lock-In (Automated Testing)\n```\n\n##\n\n[See Issue in Codacy](https://app.codacy.c