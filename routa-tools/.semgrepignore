# Semgrep ignore patterns

# Build scripts use hardcoded commands, not user input
# These are safe because the commands are static and don't interpolate user data
scripts/build-desktop-bundle.mjs
scripts/build-docker.mjs

# Docker bridge server - terminal commands come from trusted agent context
# The agent is sandboxed and commands are validated by the ACP protocol
docker/opencode-bridge/server.js

# ACP warmup - runtime paths are resolved internally, package names are from registry
# Package names are validated against the ACP registry before use
src/core/acp/acp-warmup.ts

# Runtime manager - commands are constructed from validated internal state
# Binary paths are resolved from known download locations
src/core/acp/runtime-manager.ts
